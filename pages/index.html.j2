{% macro tile(p) %}
{% set href = p.href if p.href is defined and p.href else 'product-' ~ p.slug ~ '.html' %}
{% set external = href.startswith('http') %}
<div class="pcard">
  <a class="pcard-link" href="{{ href }}"{% if external %} target="_blank" rel="noopener"{% endif %} aria-label="{{ p.model }} product page"></a>
  {% if p.image is defined and p.image %}<div class="pcard-img"><img src="{{ p.image }}" alt="{{ p.model }}" loading="lazy"></div>{% endif %}
  <div class="pcard-body">
    {% if p.is_new is defined and p.is_new %}<span class="new-badge">New</span>{% endif %}
    <div class="pmodel">{{ p.model }}</div>
    <div class="pname">{{ p.name }}</div>
    <div class="pdesc">{{ p.tile_desc if p.tile_desc is defined else p.desc }}</div>
    {% set ds = p.datasheet if p.datasheet is defined else '' %}
    {% set mn = p.manual if p.manual is defined else '' %}
    {% if ds or mn %}
    <div class="plinks" style="z-index:2;position:relative;">
      {% if ds %}<a href="{{ ds }}" target="_blank" rel="noopener">Datasheet</a>{% endif %}
      {% if mn %}<a href="{{ mn }}" target="_blank" rel="noopener">Manual</a>{% endif %}
    </div>
    {% endif %}
    {% if p.price is defined and p.price %}<div class="pcard-price">{{ p.price }}</div>{% endif %}
  </div>
</div>
{% endmacro %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stanford Research Systems — Precision Scientific Instruments</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
<script>
  function showCat(id) {
    document.querySelectorAll('.cat').forEach(function(el) { el.classList.remove('on'); });
    document.querySelectorAll('.tab').forEach(function(el) { el.classList.remove('on'); });
    var c = document.getElementById(id); if (c) c.classList.add('on');
    var b = document.querySelector('[data-cat="' + id + '"]'); if (b) b.classList.add('on');
    sessionStorage.setItem('activeTab', id);
  }
</script>

<!-- NAV -->
<nav>
  <a href="index.html" class="nav-logo">
    <img src="images/logo.svg" alt="SRS">
    <span class="nav-logo-text">Stanford Research Systems</span>
  </a>
  <ul class="nav-links">
    <li><a href="#products">Products</a></li>
    <li><a href="#support">Support</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <button class="hamburger" onclick="toggleNav()" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mob-nav" id="mobNav">
  <ul>
    <li><a href="#products" onclick="closeNav()">Products</a></li>
    <li><a href="#support" onclick="closeNav()">Support</a></li>
    <li><a href="#about" onclick="closeNav()">About</a></li>
    <li><a href="#contact" onclick="closeNav()">Contact</a></li>
  </ul>
</div>

<!-- PRODUCTS HEADER -->
<section id="products">
  <div class="s-head">
    <h2 class="s-title">Five Families of Precision Instruments</h2>
    <p class="s-sub">From lock-in amplifiers to residual gas analyzers — every SRS instrument, new or decades old, is fully supported.</p>
  </div>

  <div class="tabs">
    {% for tid, tlabel in tab_labels %}
    <button class="tab{% if loop.first %} on{% endif %}" data-cat="{{ tid }}" onclick="showCat('{{ tid }}')">{{ tlabel }}</button>
    {% endfor %}
  </div>
</section>

<!-- PRODUCT GRIDS -->
<div class="product-grids">
  <div class="container">
    {% for tab_id, tab_groups in tabs_by_group.items() %}
    <div id="{{ tab_id }}" class="cat{% if loop.first %} on{% endif %}">
      {% for group_name, group_products in tab_groups %}
      <div class="pgroup">
        <div class="pgroup-title">{{ group_name }}</div>
        <div class="pgrid">
          {% for p in group_products %}{{ tile(p) }}{% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>
</div>
<script>
(function() {
  var navEntry = performance.getEntriesByType('navigation')[0];
  if (navEntry && navEntry.type === 'back_forward') {
    var active = sessionStorage.getItem('activeTab');
    if (active) showCat(active);
  }
  var footerTab = sessionStorage.getItem('tab');
  if (footerTab) { sessionStorage.removeItem('tab'); showCat(footerTab); }
})();
</script>

