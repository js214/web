<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ model }} {{ name }} — Stanford Research Systems</title>
  <link rel="stylesheet" href="../styles.css">
  <style>
    .phero { padding: 110px 28px 0; background: #fff; }
    .phero-inner {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start;
      padding-bottom: 52px; border-bottom: 1px solid var(--border);
    }
    .phero-text .s-tag { display: block; margin-bottom: 10px; }
    .phero-model { font-size: clamp(40px, 6vw, 68px); font-weight: 700; letter-spacing: -2px; line-height: 1.0; margin-bottom: 6px; color: var(--text); }
    .phero-name { font-size: 22px; color: var(--text-sec); font-weight: 400; margin-bottom: 16px; }
    .phero-desc { font-size: 16.5px; color: var(--text-sec); line-height: 1.65; margin-bottom: 0; }
    .phero-bullets { list-style: none; margin: 0 0 16px; padding: 0; }
    .phero-bullets li { font-size: 15.4px; color: var(--text-sec); padding-left: 16px; position: relative; margin-bottom: 6px; }
    .phero-bullets li::before { content: ''; position: absolute; left: 0; top: 7px; width: 5px; height: 5px; background: var(--accent); border-radius: 50%; }
    .phero-media { display: flex; flex-direction: column; gap: 0; }
    .phero-main-img img { width: 100%; height: auto; display: block; }
    .phero-purchase { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
    .price-block { display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; }
    .price-label { font-size: 12.1px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-sec); margin-bottom: 2px; }
    .price-val { font-size: 30.8px; font-weight: 700; letter-spacing: -1px; color: var(--text); line-height: 1; }
    .purch-btn { display: flex; align-items: center; justify-content: center; text-align: center; height: 48px; border-radius: var(--radius-sm); text-decoration: none; font-size: 15.4px; font-weight: 600; transition: all var(--t); }
    .purch-btn-primary { background: var(--accent); color: #fff; }
    .purch-btn-primary:hover { background: var(--accent-h); }
    .purch-btn-outline { color: var(--accent); border: 1.5px solid var(--accent); }
    .purch-btn-outline:hover { background: var(--accent); color: #fff; }
    .phero-panel-imgs { display: flex; gap: 12px; margin-top: 12px; }
    .phero-panel-imgs img { width: calc(50% - 6px); height: auto; display: block; cursor: zoom-in; object-fit: contain; }

    .qspecs { background: #fff; padding: 48px 28px; border-bottom: 1px solid var(--border); }
    .qspecs-inner { max-width: 1100px; margin: 0 auto; }
    .qspecs-inner h2 { font-size: 19.8px; font-weight: 700; margin-bottom: 20px; letter-spacing: -0.3px; }
    .qspec-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; }
    .qspec { background: #fff; padding: 16px 18px; }
    .qspec-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; color: var(--text-sec); margin-bottom: 5px; }
    .qspec-val { font-size: 17.6px; font-weight: 600; letter-spacing: -0.2px; }

    .pdesc { padding: 56px 28px; background: #fff; border-top: 1px solid var(--border); }
    .pdesc-inner { max-width: 1100px; margin: 0 auto; }
    .pdesc-inner h2 { font-size: 26.4px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 16px; }
    .pdesc-inner p { font-size: 16.5px; color: var(--text-sec); line-height: 1.7; margin-bottom: 14px; }
    .pdesc-inner ul { list-style: none; margin: 16px 0; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 32px; }
    .pdesc-inner li { font-size: 15.4px; color: var(--text-sec); padding-left: 16px; position: relative; }
    .pdesc-inner li::before { content: ''; position: absolute; left: 0; top: 8px; width: 5px; height: 5px; background: var(--accent); border-radius: 50%; }

    .page-nav { background: #fff; border-bottom: 1px solid var(--border); padding: 0 28px; position: sticky; top: 52px; z-index: 100; }
    .page-nav-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 0; }
    .page-nav a { font-size: 14.3px; font-weight: 500; color: var(--text-sec); text-decoration: none; padding: 14px 20px; border-bottom: 2px solid transparent; transition: color var(--t), border-color var(--t); white-space: nowrap; }
    .page-nav a:hover { color: var(--accent); border-bottom-color: var(--accent); }

    .featuresec, .specsec, .tsec { scroll-margin-top: 98px; }
    .featuresec { padding: 56px 28px; background: var(--bg-alt); border-top: 1px solid var(--border); }
    .featuresec-inner { max-width: 1100px; margin: 0 auto; }
    .featuresec-inner h2 { font-size: 24.2px; font-weight: 700; letter-spacing: -0.3px; margin-bottom: 24px; color: var(--text); }
    .featuresec-inner h3 { font-size: 16.5px; font-weight: 700; margin: 28px 0 8px; color: rgb(33, 65, 139); max-width: 520px; }
    .featuresec-inner h3:first-of-type { margin-top: 0; }
    .featuresec-inner p { font-size: 15.4px; color: var(--text-sec); line-height: 1.75; margin-bottom: 12px; max-width: 520px; }
    .featuresec-inner figure { display: block; margin: 20px 0; max-width: 600px; }
    .featuresec-inner figure img { width: 100%; height: auto; display: block; }
    .featuresec-inner figcaption { font-size: 12.1px; color: var(--text-sec); text-align: center; margin-top: 6px; font-style: italic; line-height: 1.4; }
    .featuresec-inner .fig-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin: 24px 0; max-width: 100%; }
    .featuresec-inner .fig-grid figure { max-width: 100%; margin: 0; }
    @media (min-width: 860px) {
      .featuresec-inner figure { float: right; clear: right; width: 44%; max-width: 44%; margin: 0 0 20px 28px; }
      .featuresec-inner .fig-grid figure { float: none; width: auto; max-width: 100%; margin: 0; }
      .featuresec-inner::after { content: ''; display: table; clear: both; }
    }
    @media (max-width: 859px) {
      .featuresec-inner h3,
      .featuresec-inner p { max-width: 100%; }
      .featuresec-inner .fig-grid { grid-template-columns: 1fr; }
    }
    .specsec { padding: 56px 28px; background: #fff; }
    .specsec-inner { max-width: 1100px; margin: 0 auto; }
    .specsec-inner h2 { font-size: 24.2px; font-weight: 700; letter-spacing: -0.3px; margin-bottom: 24px; color: var(--text); }
    .st { width: 100%; border-collapse: collapse; }
    .st td { padding: 11px 14px; border-bottom: 1px solid var(--border); font-size: 14.3px; vertical-align: top; }
    .st td:first-child { width: 38%; color: var(--text-sec); font-weight: 500; }
    .st tr:hover td { background: var(--bg-alt); }
    .st-group td { background: var(--bg-alt); font-size: 12.1px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-sec); padding: 8px 14px; }

    .tsec { padding: 56px 28px; background: var(--bg-alt); border-top: 1px solid var(--border); }
    .tsec-inner { max-width: 1100px; margin: 0 auto; }
    .tsec-inner h2 { font-size: 24.2px; font-weight: 700; letter-spacing: -0.3px; margin-bottom: 8px; color: var(--text); }
    .tsec-inner > p { font-size: 15.4px; color: var(--text-sec); margin-bottom: 32px; }
    .titem { border: 1px solid var(--border); border-radius: var(--radius-sm); background: #fff; margin-bottom: 10px; overflow: hidden; }
    .titem summary { padding: 16px 20px; font-size: 16.5px; font-weight: 500; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
    .titem summary::-webkit-details-marker { display: none; }
    .titem summary::after { content: '+'; font-size: 22px; font-weight: 300; color: var(--text-sec); flex-shrink: 0; }
    .titem[open] summary::after { content: '−'; }
    .titem-body { padding: 0 20px 18px; font-size: 15.4px; color: var(--text-sec); line-height: 1.7; border-top: 1px solid var(--border); margin-top: 0; padding-top: 16px; }

    .lightbox { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.85); z-index: 9999; align-items: center; justify-content: center; cursor: zoom-out; }
    .lightbox.open { display: flex; }
    .lightbox img { max-width: 90vw; max-height: 90vh; object-fit: contain; display: block; }
    .lightbox-close { position: absolute; top: 20px; right: 28px; font-size: 35.2px; color: #fff; cursor: pointer; line-height: 1; user-select: none; }
    @media (max-width: 768px) {
      .phero-inner { grid-template-columns: 1fr; gap: 28px; }
      .phero-media { order: -1; }
      .price-val { font-size: 33px; }
    }
    @media (max-width: 480px) {
      .phero-ctas { flex-direction: column; }
      .btn-buy { text-align: center; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="../index.html" class="nav-logo">
    <img src="../images/logo.svg" alt="SRS">
    <span class="nav-logo-text">Stanford Research Systems</span>
  </a>
  <ul class="nav-links">
    <li><a href="../index.html#products">Products</a></li>
    <li><a href="../index.html#support">Support</a></li>
    <li><a href="../index.html#about">About</a></li>
    <li><a href="../index.html#contact">Contact</a></li>
  </ul>
  <button class="hamburger" onclick="toggleNav()" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>
<div class="mob-nav" id="mobNav">
  <ul>
    <li><a href="../index.html#products" onclick="closeNav()">Products</a></li>
    <li><a href="../index.html#support" onclick="closeNav()">Support</a></li>
    <li><a href="../index.html#about" onclick="closeNav()">About</a></li>
    <li><a href="../index.html#contact" onclick="closeNav()">Contact</a></li>
  </ul>
</div>

<!-- LIGHTBOX -->
<div class="lightbox" id="lb" onclick="closeLB()">
  <span class="lightbox-close" onclick="closeLB()">×</span>
  <img id="lb-img" src="" alt="">
</div>

<!-- HERO -->
<div class="phero">
  <div class="phero-inner">
    <div class="phero-text">
      <span class="s-tag">{{ group if group is defined else "" }}</span>
      <div class="phero-model">{{ model }}</div>
      <div class="phero-name">{{ name }}</div>
      {% if description_bullets is defined and description_bullets %}
      <ul class="phero-bullets">
        {% for bullet in description_bullets %}
        <li>{{ bullet }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if tile_desc is defined and tile_desc %}<div class="phero-desc">{{ tile_desc }}</div>{% endif %}
    </div>
    <div class="phero-media">
      <div class="phero-purchase">
        <div class="price-block">
          <div class="price-label">List Price{% if price_prefix is defined and price_prefix %} — {{ price_prefix }}{% endif %}</div>
          <div class="price-val">{% if price is defined and price %}{{ price }}{% else %}Contact us{% endif %}</div>
        </div>
        <a href="../index.html#contact" class="purch-btn purch-btn-primary">Buy Now</a>
      </div>
      {% if image is defined and image %}
      {% set img_src = image if image.startswith('http') else '../' + image %}
      <div class="phero-main-img">
        <img src="{{ img_src }}" alt="{{ model }}" loading="lazy" onclick="openLB('{{ img_src }}')" style="cursor:zoom-in">
      </div>
      <div class="phero-panel-imgs">
        {% set fp = 'https://thinksrs.com/images/instr/' + slug + '/' + model + '_FPlg.jpg' %}
        {% set rp = 'https://thinksrs.com/images/instr/' + slug + '/' + model + '_RPlg.jpg' %}
        <img src="{{ fp }}" alt="{{ model }} front panel" loading="lazy" onclick="openLB('{{ fp }}')" onerror="this.parentElement.style.display='none'">
        <img src="{{ rp }}" alt="{{ model }} rear panel" loading="lazy" onclick="openLB('{{ rp }}')" onerror="this.parentElement.removeChild(this)">
      </div>
      {% endif %}
    </div>
  </div>
</div>


<!-- PAGE NAV -->
<nav class="page-nav">
  <div class="page-nav-inner">
    {% if body_html %}<a href="#sec-features">Features</a>{% endif %}
    {% if spec_groups is defined and spec_groups %}<a href="#sec-specs">Specifications</a>{% endif %}
    {% if troubleshooting is defined and troubleshooting %}<a href="#sec-troubleshooting">Troubleshooting</a>{% endif %}
    {% set ds = datasheet if datasheet is defined else "" %}
    {% set mn = manual if manual is defined else "" %}
    {% if ds %}<a href="{{ ds }}" target="_blank" rel="noopener">Datasheet</a>{% endif %}
    {% if mn %}<a href="{{ mn }}" target="_blank" rel="noopener">Manual</a>{% endif %}
  </div>
</nav>

{% if body_html %}
<!-- FEATURES -->
<div class="featuresec" id="sec-features">
  <div class="featuresec-inner">
    <h2>Features</h2>
    {{ body_html | safe }}
  </div>
</div>
{% endif %}

{% if spec_groups is defined and spec_groups %}
<!-- FULL SPECS -->
<div class="specsec" id="sec-specs">
  <div class="specsec-inner">
    <h2>Full Specifications</h2>
    <table class="st">
      <tbody>
        {% for group in spec_groups %}
        <tr class="st-group"><td colspan="2">{{ group.name }}</td></tr>
        {% for row in group.rows %}
        <tr><td>{{ row[0] }}</td><td>{{ row[1] }}</td></tr>
        {% endfor %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}

{% if troubleshooting is defined and troubleshooting %}
<!-- TROUBLESHOOTING -->
<div class="tsec" id="sec-troubleshooting">
  <div class="tsec-inner">
    <h2>Troubleshooting</h2>
    <p>Common issues and solutions for the {{ model }}.</p>
    {% for item in troubleshooting %}
    <details class="titem">
      <summary>{{ item.q }}</summary>
      <div class="titem-body">{{ item.a }}</div>
    </details>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- FOOTER -->
{% set base = "../" %}
{% include '_footer.j2' %}

<script>
  var lbSrcs = [], lbIdx = 0;
  function buildLBSrcs() {
    lbSrcs = Array.from(document.querySelectorAll('.phero-main-img img, .phero-panel-imgs img')).map(function(i){return i.src;});
  }
  function openLB(src) {
    buildLBSrcs();
    lbIdx = lbSrcs.indexOf(src);
    if (lbIdx < 0) lbIdx = 0;
    document.getElementById('lb-img').src = src;
    document.getElementById('lb').classList.add('open');
  }
  function closeLB() { document.getElementById('lb').classList.remove('open'); document.getElementById('lb-img').src = ''; }
  function lbNav(dir) {
    if (!document.getElementById('lb').classList.contains('open')) return;
    lbIdx = (lbIdx + dir + lbSrcs.length) % lbSrcs.length;
    document.getElementById('lb-img').src = lbSrcs[lbIdx];
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeLB();
    else if (e.key === 'ArrowRight') lbNav(1);
    else if (e.key === 'ArrowLeft') lbNav(-1);
  });
  function toggleNav() { document.getElementById('mobNav').classList.toggle('open'); }
  function closeNav()  { document.getElementById('mobNav').classList.remove('open'); }
</script>
</body>
</html>
