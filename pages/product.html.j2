<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ model }} {{ name }} — Stanford Research Systems</title>
  <link rel="stylesheet" href="../styles.css">
  <style>
    .phero { padding: 110px 28px 0; background: #fff; }
    .phero-inner {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: stretch;
      padding-bottom: 52px;
    }
    .phero-text { display: flex; flex-direction: column; }
    .phero-text .s-tag { display: block; margin-bottom: 10px; text-decoration: none; }
    .phero-text .s-tag:hover { text-decoration: underline; }
    .phero-model { font-size: clamp(40px, 6vw, 68px); font-weight: 700; letter-spacing: -2px; line-height: 1.0; margin-bottom: 6px; color: var(--text); }
    .phero-name { font-size: 22px; color: var(--text-sec); font-weight: 400; margin-bottom: 16px; }
    .phero-desc { font-size: 16.5px; color: var(--text-sec); line-height: 1.65; margin-bottom: 0; }
    .phero-bullets { list-style: none; margin: 0 0 16px; padding: 0; }
    .phero-bullets li { font-size: 15.4px; color: var(--text-sec); padding-left: 16px; position: relative; margin-bottom: 6px; }
    .phero-bullets li::before { content: ''; position: absolute; left: 0; top: 7px; width: 5px; height: 5px; background: var(--accent); border-radius: 50%; }
    .phero-media { display: flex; flex-direction: column; gap: 0; }
    .phero-main-img { flex: 1; min-height: 150px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .phero-main-img img { width: 100%; height: 100%; object-fit: contain; display: block; }
    .phero-purchase { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: auto; padding-top: 12px; min-height: 160px; align-content: center; }
    .price-block { display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; }
    .price-label { font-size: 12.1px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-sec); margin-bottom: 2px; }
    .price-val { font-size: 30.8px; font-weight: 700; letter-spacing: -1px; color: var(--text); line-height: 1; }
    .purch-btn { display: flex; align-items: center; justify-content: center; text-align: center; height: 48px; border-radius: var(--radius-sm); text-decoration: none; font-size: 15.4px; font-weight: 600; transition: all var(--t); }
    .purch-btn-primary { background: var(--accent); color: #fff; }
    .purch-btn-primary:hover { background: var(--accent-h); }
    .purch-btn-outline { color: var(--accent); border: 1.5px solid var(--accent); }
    .purch-btn-outline:hover { background: var(--accent); color: #fff; }
    .phero-panel-imgs { display: flex; gap: 12px; margin-top: 12px; height: 160px; }
    .phero-panel-imgs img { width: calc(50% - 6px); height: 100%; object-fit: contain; display: block; cursor: zoom-in; }

    .qspecs { background: #fff; padding: 48px 28px; border-bottom: 1px solid var(--border); }
    .qspecs-inner { max-width: 1100px; margin: 0 auto; }
    .qspecs-inner h2 { font-size: 19.8px; font-weight: 700; margin-bottom: 20px; letter-spacing: -0.3px; }
    .qspec-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; }
    .qspec { background: #fff; padding: 16px 18px; }
    .qspec-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; color: var(--text-sec); margin-bottom: 5px; }
    .qspec-val { font-size: 17.6px; font-weight: 600; letter-spacing: -0.2px; }

    .pdesc { padding: 56px 28px; background: #fff; border-top: 1px solid var(--border); }
    .pdesc-inner { max-width: 1100px; margin: 0 auto; }
    .pdesc-inner h2 { font-size: 26.4px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 16px; }
    .pdesc-inner p { font-size: 16.5px; color: var(--text-sec); line-height: 1.7; margin-bottom: 14px; }
    .pdesc-inner ul { list-style: none; margin: 16px 0; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 32px; }
    .pdesc-inner li { font-size: 15.4px; color: var(--text-sec); padding-left: 16px; position: relative; }
    .pdesc-inner li::before { content: ''; position: absolute; left: 0; top: 8px; width: 5px; height: 5px; background: var(--accent); border-radius: 50%; }

    .page-nav { background: #fff; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 6px 28px; position: sticky; top: 52px; z-index: 100; height: auto; }
    .page-nav-inner { max-width: 1100px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 4px 0; }
    .page-nav a { font-size: 14.3px; font-weight: 500; color: var(--text-sec); text-decoration: none; padding: 10px 20px; transition: color var(--t); white-space: nowrap; }
    .page-nav a:hover { color: var(--accent); }
    .page-nav a.active { color: var(--accent); font-weight: 700; }

    .featuresec, .specsec, .tsec { scroll-margin-top: 98px; }
    .featuresec { padding: 56px 28px; background: var(--bg-alt); border-top: 1px solid var(--border); }
    .featuresec-inner { max-width: 1100px; margin: 0 auto; }
    .featuresec-inner h2 { font-size: 24.2px; font-weight: 700; letter-spacing: -0.3px; margin-bottom: 24px; color: var(--text); }
    .featuresec-inner h3 { font-size: 16.5px; font-weight: 700; margin: 28px 0 8px; color: rgb(33, 65, 139); max-width: 520px; }
    .featuresec-inner h3:first-of-type { margin-top: 0; }
    .featuresec-inner p { font-size: 15.4px; color: var(--text-sec); line-height: 1.75; margin-bottom: 12px; max-width: 520px; }
    .featuresec-inner figure { display: block; margin: 20px 0; max-width: 600px; }
    .featuresec-inner figure img { width: 100%; height: auto; display: block; }
    .featuresec-inner figcaption { font-size: 12.1px; color: var(--text-sec); text-align: center; margin-top: 6px; font-style: italic; line-height: 1.4; }
    .featuresec-inner .fig-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin: 24px 0; max-width: 100%; }
    .featuresec-inner .fig-grid figure { max-width: 100%; margin: 0; }
    @media (min-width: 860px) {
      .featuresec-inner figure { float: right; clear: right; width: 44%; max-width: 44%; margin: 0 0 20px 28px; }
      .featuresec-inner .fig-grid figure { float: none; width: auto; max-width: 100%; margin: 0; }
      .featuresec-inner figure:last-child { float: none; width: 100%; max-width: 100%; margin: 24px 0; }
      .featuresec-inner::after { content: ''; display: table; clear: both; }
    }
    @media (max-width: 859px) {
      .featuresec-inner h3,
      .featuresec-inner p { max-width: 100%; }
      .featuresec-inner .fig-grid { grid-template-columns: 1fr; }
    }
    .specsec { padding: 56px 28px; background: #fff; }
    .specsec-inner { max-width: 1100px; margin: 0 auto; }
    .specsec-inner h2 { font-size: 24.2px; font-weight: 700; letter-spacing: -0.3px; margin-bottom: 24px; color: var(--text); }
    .st { width: 100%; border-collapse: collapse; }
    .st td { padding: 11px 14px; border-bottom: 1px solid var(--border); font-size: 14.3px; vertical-align: top; }
    .st td:first-child { width: 38%; color: var(--text-sec); font-weight: 500; }
    .st tr:hover td { background: var(--bg-alt); }
    .st-group td { background: var(--bg-alt); font-size: 12.1px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-sec); padding: 8px 14px; }

    .linksec { padding: 40px 28px; background: #fff; border-top: 1px solid var(--border); scroll-margin-top: 98px; }
    .linksec-inner { max-width: 1100px; margin: 0 auto; }
    .linksec-inner h2 { font-size: 24.2px; font-weight: 700; letter-spacing: -0.3px; margin-bottom: 16px; color: var(--text); }
    .link-list { list-style: none; margin: 0; padding: 0; }
    .link-list li { padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 15.4px; }
    .link-list li:last-child { border-bottom: none; }
    .link-list a { color: var(--text); text-decoration: none; }
    .link-list a:hover { color: var(--accent); }

    .res-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; }
    .res-card { display: flex; align-items: center; gap: 12px; padding: 14px 16px; border: 1px solid var(--border); border-radius: var(--radius-sm); text-decoration: none; color: var(--text); transition: all var(--t); }
    .res-card:hover { border-color: var(--accent); box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .res-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .res-icon svg { width: 20px; height: 20px; }
    .res-pdf { background: #fee2e2; color: #dc2626; }
    .res-yt { background: #fee2e2; color: #dc2626; }
    .res-gh { background: #f0fdf4; color: #16a34a; }
    .res-zip { background: #eff6ff; color: var(--accent); }
    .res-label { font-size: 13.5px; font-weight: 500; line-height: 1.3; }

    .rel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 14px; }
    .rel-card { display: flex; flex-direction: column; border: 1px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; text-decoration: none; color: var(--text); transition: all var(--t); }
    .rel-card:hover { border-color: var(--accent); box-shadow: 0 4px 16px rgba(0,0,0,0.08); transform: translateY(-2px); }
    .rel-img { height: 120px; background: #fff; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .rel-img img { width: 100%; height: 100%; object-fit: contain; padding: 10px; }
    .rel-body { padding: 12px 14px; }
    .rel-model { font-size: 11px; font-weight: 600; color: var(--accent); letter-spacing: 0.5px; text-transform: uppercase; font-family: 'Courier New', monospace; margin-bottom: 4px; }
    .rel-name { font-size: 13.5px; font-weight: 500; line-height: 1.3; }

    .tsec { padding: 56px 28px; background: var(--bg-alt); border-top: 1px solid var(--border); }
    .tsec-inner { max-width: 1100px; margin: 0 auto; }
    .tsec-inner h2 { font-size: 24.2px; font-weight: 700; letter-spacing: -0.3px; margin-bottom: 8px; color: var(--text); }
    .tsec-inner > p { font-size: 15.4px; color: var(--text-sec); margin-bottom: 32px; }
    .titem { border: 1px solid var(--border); border-radius: var(--radius-sm); background: #fff; margin-bottom: 10px; overflow: hidden; }
    .titem summary { padding: 16px 20px; font-size: 16.5px; font-weight: 500; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
    .titem summary::-webkit-details-marker { display: none; }
    .titem summary::after { content: '+'; font-size: 22px; font-weight: 300; color: var(--text-sec); flex-shrink: 0; }
    .titem[open] summary::after { content: '−'; }
    .titem-body { padding: 0 20px 18px; font-size: 15.4px; color: var(--text-sec); line-height: 1.7; border-top: 1px solid var(--border); margin-top: 0; padding-top: 16px; }

    .lightbox { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.85); z-index: 9999; align-items: center; justify-content: center; cursor: zoom-out; }
    .lightbox.open { display: flex; }
    .lightbox img { max-width: 90vw; max-height: 90vh; object-fit: contain; display: block; transition: transform 0.15s ease; transform-origin: center center; }
    .lightbox-close { position: absolute; top: 20px; right: 28px; font-size: 35.2px; color: #fff; cursor: pointer; line-height: 1; user-select: none; }
    @media (max-width: 768px) {
      .phero-inner { grid-template-columns: 1fr; gap: 28px; }
      .price-val { font-size: 33px; }
    }
    @media (max-width: 480px) {
      .phero-ctas { flex-direction: column; }
      .btn-buy { text-align: center; }
    }
    .disc-block { display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; gap: 6px; }
    .disc-label { font-size: 13.2px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #b71c1c; }
    .disc-successor { font-size: 14.3px; color: var(--text-sec); }
    .disc-successor a { color: var(--accent); text-decoration: none; font-weight: 600; }
    .disc-successor a:hover { text-decoration: underline; }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="../index.html" class="nav-logo">
    <img src="../images/logo.svg" alt="SRS">
    <span class="nav-logo-text">Stanford Research Systems</span>
  </a>
  <ul class="nav-links">
    <li><a href="../index.html#products">Products</a></li>
    <li><a href="../index.html#support">Support</a></li>
    <li><a href="../index.html#about">About</a></li>
    <li><a href="../index.html#contact">Contact</a></li>
  </ul>
  <button class="hamburger" onclick="toggleNav()" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>
<div class="mob-nav" id="mobNav">
  <ul>
    <li><a href="../index.html#products" onclick="closeNav()">Products</a></li>
    <li><a href="../index.html#support" onclick="closeNav()">Support</a></li>
    <li><a href="../index.html#about" onclick="closeNav()">About</a></li>
    <li><a href="../index.html#contact" onclick="closeNav()">Contact</a></li>
  </ul>
</div>

<!-- LIGHTBOX -->
<div class="lightbox" id="lb" onclick="closeLB()">
  <span class="lightbox-close" onclick="closeLB()">×</span>
  <img id="lb-img" src="" alt="">
</div>

<!-- HERO -->
<div class="phero">
  <div class="phero-inner">
    <div class="phero-text">
      {% if group_display is defined and group_display %}<a class="s-tag" href="../index.html" onclick="sessionStorage.setItem('tab','{{ primary_tab }}');sessionStorage.setItem('group','group-{{ group_display | slugify }}')">{{ group_display }}</a>{% endif %}
      <div class="phero-model">{{ model }}{% if future is defined and future %} <span class="future-badge">Future</span>{% elif is_new is defined and is_new %} <span class="new-badge">New</span>{% endif %}</div>
      <div class="phero-name">{{ name }}</div>
      {% if description_bullets is defined and description_bullets %}
      <ul class="phero-bullets">
        {% for bullet in description_bullets %}
        <li>{{ bullet }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if tile_desc is defined and tile_desc %}<div class="phero-desc">{{ tile_desc }}</div>{% endif %}
      <div class="phero-purchase">
        {% if discontinued is defined and discontinued %}
        <div class="disc-block" style="grid-column:1/-1">
          <div class="disc-label">Discontinued</div>
          {% if successor_label is defined and successor_label %}<div class="disc-successor">See the <a href="{{ successor_url }}">{{ successor_label }}</a></div>{% endif %}
        </div>
        {% elif future is defined and future %}
        <div class="price-block">
          <div class="price-label">List Price</div>
          <div class="price-val">{% if price is defined and price %}{{ price }}{% else %}TBD{% endif %}</div>
        </div>
        <a href="../sim/" target="_blank" rel="noopener" class="purch-btn purch-btn-primary" style="background:#7b1fa2">Try Now</a>
        {% else %}
        <div class="price-block">
          <div class="price-label">List Price{% if price_prefix is defined and price_prefix %} — {{ price_prefix }}{% endif %}</div>
          <div class="price-val">{% if price is defined and price %}{{ price }}{% else %}Contact us{% endif %}</div>
        </div>
        {% set order_url = buy_url if buy_url is defined and buy_url else 'https://orders.thinksrs.com/OnlineOrders/SRSOrders.html?EPrdGrp=' + model.split('/')[0].strip().replace(' ', '') %}
        <a href="{{ order_url }}" target="_blank" rel="noopener" class="purch-btn purch-btn-primary">Buy Now</a>
        {% endif %}
      </div>
    </div>
    <div class="phero-media">
      {% if image is defined and image %}
      {% set img_src = image if image.startswith('http') else '../' + image %}
      <div class="phero-main-img">
        <img src="{{ img_src }}" alt="{{ model }}" loading="lazy" onclick="openLB('{{ img_src }}')" style="cursor:zoom-in">
      </div>
      <div class="phero-panel-imgs">
        {% if panels is defined and panels %}
        {% set fp = panels[0] if panels[0].startswith('http') else '../' + panels[0] %}
        {% set rp = panels[1] if panels|length > 1 and panels[1].startswith('http') else ('../' + panels[1] if panels|length > 1 else '') %}
        {% else %}
        {% set fp = '../images/instr/' + slug + '/' + model + '_FPlg.jpg' %}
        {% set rp = '../images/instr/' + slug + '/' + model + '_RPlg.jpg' %}
        {% endif %}
        <img src="{{ fp }}" alt="{{ model }} front panel" loading="lazy" onclick="openLB('{{ fp }}')" onerror="this.parentElement.style.display='none'">
        {% if rp %}<img src="{{ rp }}" alt="{{ model }} rear panel" loading="lazy" onclick="openLB('{{ rp }}')" onerror="this.parentElement.removeChild(this)">{% endif %}
      </div>
      {% endif %}
    </div>
  </div>
</div>


<!-- PAGE NAV -->
<nav class="page-nav">
  <div class="page-nav-inner">
    {% if body_html %}<a href="#sec-features">Features</a>{% endif %}
    {% if spec_groups is defined and spec_groups %}<a href="#sec-specs">Specifications</a>{% endif %}
    {% if troubleshooting is defined and troubleshooting %}<a href="#sec-troubleshooting">Troubleshooting</a>{% endif %}
    {% if resources is defined and resources %}<a href="#sec-resources">Resources</a>{% endif %}
    {% if related is defined and related %}<a href="#sec-related">Related Products</a>{% endif %}
    {% set ds = datasheet if datasheet is defined else "" %}
    {% set mn = manual if manual is defined else "" %}
    {% if ds %}{% set ds_href = ds if ds.startswith('http') else '../' + ds %}<a href="{{ ds_href }}" target="_blank" rel="noopener">Datasheet</a>{% endif %}
    {% if mn %}{% set mn_href = mn if mn.startswith('http') else '../' + mn %}<a href="{{ mn_href }}" target="_blank" rel="noopener">Manual</a>{% endif %}
  </div>
</nav>

{% if body_html %}
<!-- FEATURES -->
<div class="featuresec" id="sec-features">
  <div class="featuresec-inner">
    <h2>Features</h2>
    {{ body_html | safe }}
  </div>
</div>
{% endif %}

{% if spec_groups is defined and spec_groups %}
<!-- FULL SPECS -->
<div class="specsec" id="sec-specs">
  <div class="specsec-inner">
    <h2>Full Specifications</h2>
    <table class="st">
      <tbody>
        {% for group in spec_groups %}
        <tr class="st-group"><td colspan="2">{{ group.name }}</td></tr>
        {% for row in group.rows %}
        <tr><td>{{ row[0] }}</td><td>{{ row[1] }}</td></tr>
        {% endfor %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}

{% if troubleshooting is defined and troubleshooting %}
<!-- TROUBLESHOOTING -->
<div class="tsec" id="sec-troubleshooting">
  <div class="tsec-inner">
    <h2>Troubleshooting</h2>
    <p>Common issues and solutions for the {{ model }}.</p>
    {% for item in troubleshooting %}
    <details class="titem">
      <summary>{{ item.q }}</summary>
      <div class="titem-body">{{ item.a }}</div>
    </details>
    {% endfor %}
  </div>
</div>
{% endif %}

{% if resources is defined and resources %}
<!-- RESOURCES -->
<div class="linksec" id="sec-resources">
  <div class="linksec-inner">
    <h2>Resources</h2>
    <div class="res-grid">
      {% for r in resources %}
      {% if 'youtube' in r.url %}{% set iclass = 'res-yt' %}{% set svg = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 00.5 6.2 31.3 31.3 0 000 12a31.3 31.3 0 00.5 5.8 3 3 0 002.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 002.1-2.1A31.3 31.3 0 0024 12a31.3 31.3 0 00-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>' %}
      {% elif 'github' in r.url %}{% set iclass = 'res-gh' %}{% set svg = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .1-.78.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 016.02 0c2.28-1.55 3.28-1.23 3.28-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.82.58A12 12 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>' %}
      {% elif r.url.endswith('.zip') or r.url.endswith('.exe') %}{% set iclass = 'res-zip' %}{% set svg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>' %}
      {% else %}{% set iclass = 'res-pdf' %}{% set svg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>' %}
      {% endif %}
      <a href="{{ r.url }}" target="_blank" rel="noopener" class="res-card">
        <span class="res-icon {{ iclass }}">{{ svg }}</span>
        <span class="res-label">{{ r.label }}</span>
      </a>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

{% if related is defined and related %}
<!-- RELATED PRODUCTS -->
<div class="linksec" id="sec-related">
  <div class="linksec-inner">
    <h2>Related Products</h2>
    <div class="rel-grid">
      {% for r in related %}
      {% set rslug = r.url.replace('.html','') %}
      {% set rp = all_products[rslug] if all_products is defined and rslug in all_products else none %}
      {% if rp %}
      <a href="{{ r.url }}" class="rel-card">
        {% if rp.image is defined and rp.image %}<div class="rel-img"><img src="../{{ rp.image }}" alt="{{ rp.model }}" loading="lazy"></div>{% endif %}
        <div class="rel-body">
          <div class="rel-model">{{ rp.model }}</div>
          <div class="rel-name">{{ rp.name }}</div>
        </div>
      </a>
      {% else %}
      <a href="{{ r.url }}" {% if r.url.startswith('http') %}target="_blank" rel="noopener"{% endif %} class="rel-card">
        <div class="rel-body">
          <div class="rel-name">{{ r.label }}</div>
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

<!-- FOOTER -->
{% set base = "../" %}
{% include '_footer.j2' %}

<script>
  var lbSrcs = [], lbIdx = 0;
  function buildLBSrcs() {
    lbSrcs = [...new Set(Array.from(document.querySelectorAll('.phero-main-img img, .phero-panel-imgs img')).map(function(i){return i.src;}))];
  }
  function openLB(src) {
    buildLBSrcs();
    // Resolve relative path to absolute for comparison
    var a = document.createElement('a'); a.href = src; var abs = a.href;
    lbIdx = lbSrcs.indexOf(abs);
    if (lbIdx < 0) lbIdx = 0;
    document.getElementById('lb-img').src = src;
    document.getElementById('lb').classList.add('open');
  }
  var lbZoom = 1;
  function closeLB() {
    document.getElementById('lb').classList.remove('open');
    document.getElementById('lb-img').src = '';
    lbZoom = 1;
    document.getElementById('lb-img').style.transform = '';
  }
  function lbNav(dir) {
    if (!document.getElementById('lb').classList.contains('open')) return;
    lbIdx = (lbIdx + dir + lbSrcs.length) % lbSrcs.length;
    document.getElementById('lb-img').src = lbSrcs[lbIdx];
    lbZoom = 1;
    document.getElementById('lb-img').style.transform = '';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeLB();
    else if (e.key === 'ArrowRight') lbNav(1);
    else if (e.key === 'ArrowLeft') lbNav(-1);
  });
  document.getElementById('lb').addEventListener('wheel', function(e) {
    if (!this.classList.contains('open')) return;
    e.preventDefault();
    var delta = e.deltaY > 0 ? 0.9 : 1.1;
    lbZoom = Math.min(Math.max(lbZoom * delta, 0.5), 10);
    document.getElementById('lb-img').style.transform = 'scale(' + lbZoom + ')';
  }, { passive: false });
  function toggleNav() { document.getElementById('mobNav').classList.toggle('open'); }
  function closeNav()  { document.getElementById('mobNav').classList.remove('open'); }

  // Highlight active section in page-nav
  (function() {
    var navLinks = document.querySelectorAll('.page-nav a[href^="#"]');
    if (!navLinks.length) return;
    var sections = [];
    navLinks.forEach(function(a) {
      var id = a.getAttribute('href').slice(1);
      var el = document.getElementById(id);
      if (el) sections.push({ el: el, link: a });
    });
    if (!sections.length) return;
    function update() {
      var best = null, bestDist = Infinity;
      sections.forEach(function(s) {
        var r = s.el.getBoundingClientRect();
        var dist = Math.abs(r.top - 120);
        if (r.top < window.innerHeight && r.bottom > 0 && dist < bestDist) {
          bestDist = dist; best = s;
        }
      });
      navLinks.forEach(function(a) { a.classList.remove('active'); });
      if (best) best.link.classList.add('active');
    }
    window.addEventListener('scroll', update, { passive: true });
    update();
  })();
</script>
</body>
</html>
