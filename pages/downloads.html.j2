<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Downloads — Stanford Research Systems</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

<!-- NAV -->
<nav>
  <a href="index.html" class="nav-logo">
    <img src="images/logo.svg" alt="SRS">
    <span class="nav-logo-text">Stanford Research Systems</span>
  </a>
  <ul class="nav-links">
    <li><a href="index.html#products">Products</a></li>
    <li><a href="index.html#support">Support</a></li>
    <li><a href="index.html#about">About</a></li>
    <li><a href="index.html#contact">Contact</a></li>
  </ul>
  <button class="hamburger" onclick="toggleNav()" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mob-nav" id="mobNav">
  <ul>
    <li><a href="index.html#products" onclick="closeNav()">Products</a></li>
    <li><a href="index.html#support" onclick="closeNav()">Support</a></li>
    <li><a href="index.html#about" onclick="closeNav()">About</a></li>
    <li><a href="index.html#contact" onclick="closeNav()">Contact</a></li>
  </ul>
</div>

<!-- HERO -->
<div class="page-hero">
  <span class="s-tag">Downloads</span>
  <h1>Downloads</h1>
  <p>Datasheets, manuals, and application notes for all SRS instruments.</p>
</div>

<!-- APP NOTES -->
{% if app_notes %}
<section class="inner-section">
  <div class="inner-wrap" style="max-width:1100px">
    <h2 style="font-size:24.2px;font-weight:700;letter-spacing:-0.3px;margin-bottom:20px;color:var(--text)">Application Notes</h2>
    {% for category, notes in app_notes.items() %}
    <h3 style="font-size:15.4px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:0.5px;margin:24px 0 10px">{{ category }}</h3>
    <table class="dl-table">
      <tbody>
        {% for n in notes %}
        <tr>
          <td style="color:var(--text)">{{ n.label }}</td>
          <td style="width:60px;text-align:right"><a href="{{ n.url }}" target="_blank" rel="noopener">PDF</a></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endfor %}
  </div>
</section>
{% endif %}

<!-- MANUALS & DATASHEETS -->
<section class="inner-section alt">
  <div class="inner-wrap" style="max-width:1100px">
    <h2 style="font-size:24.2px;font-weight:700;letter-spacing:-0.3px;margin-bottom:20px;color:var(--text)">Manuals &amp; Datasheets</h2>

    <div class="filter-tabs">
      <button class="filter-tab on" onclick="showDl('all')">All</button>
      {% for tid, tlabel in tab_labels %}{% if tid != 'new' %}
      <button class="filter-tab" onclick="showDl('{{ tid }}')">{{ tlabel }}</button>
      {% endif %}{% endfor %}
    </div>

    <!-- ALL -->
    <div class="dl-section on" id="dl-all">
      <table class="dl-table">
        <thead><tr><th>Model</th><th>Name</th><th>Datasheet</th><th>Manual</th></tr></thead>
        <tbody>
          {% for slug, p in products.items()|sort %}
          <tr>
            <td class="dl-model"><a href="products/{{ p.slug }}.html">{{ p.model }}</a></td>
            <td>{{ p.name }}</td>
            <td>{% if p.datasheet is defined and p.datasheet %}<a href="{{ p.datasheet }}" target="_blank" rel="noopener">PDF</a>{% endif %}</td>
            <td>{% if p.manual is defined and p.manual %}<a href="{{ p.manual }}" target="_blank" rel="noopener">PDF</a>{% endif %}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% for tid, tlabel in tab_labels %}{% if tid != 'new' %}
    <div class="dl-section" id="dl-{{ tid }}">
      <table class="dl-table">
        <thead><tr><th>Model</th><th>Name</th><th>Datasheet</th><th>Manual</th></tr></thead>
        <tbody>
          {% for slug, p in products.items()|sort %}{% if slug_placement.get(slug, ('',''))[0] == tid %}
          <tr>
            <td class="dl-model"><a href="products/{{ p.slug }}.html">{{ p.model }}</a></td>
            <td>{{ p.name }}</td>
            <td>{% if p.datasheet is defined and p.datasheet %}<a href="{{ p.datasheet }}" target="_blank" rel="noopener">PDF</a>{% endif %}</td>
            <td>{% if p.manual is defined and p.manual %}<a href="{{ p.manual }}" target="_blank" rel="noopener">PDF</a>{% endif %}</td>
          </tr>
          {% endif %}{% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}{% endfor %}

  </div>
</section>

<!-- FOOTER -->
{% include '_footer.j2' %}

<script>
  function showDl(id) {
    document.querySelectorAll('.dl-section').forEach(function(el) { el.classList.remove('on'); });
    document.querySelectorAll('.filter-tab').forEach(function(el) { el.classList.remove('on'); });
    document.getElementById('dl-' + id).classList.add('on');
    event.currentTarget.classList.add('on');
  }
  function toggleNav() { document.getElementById('mobNav').classList.toggle('open'); }
  function closeNav()  { document.getElementById('mobNav').classList.remove('open'); }
</script>
</body>
</html>
